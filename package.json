{
  "name": "transcribe-broadcast",
  "version": "0.1.0",
  "private": true,
  "main": "server/server.js",
  "scripts": {
    "install-all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run dev --prefix client\" \"nodemon server/server.js\"",
    "build": "cd client && npm run build",
    "start": "node server/server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ffmpeg-static": "^5.2.0",
    "nodejs-whisper": "^0.3.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  },
  "nodemonConfig": {
    "ignore": [
      "server/segments/*"
    ]
  }
}
